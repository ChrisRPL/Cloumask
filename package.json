{
  "name": "cloumask",
  "version": "0.1.0",
  "description": "Local-first agentic CV data processing",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "backend:dev": "cd backend && source .venv/bin/activate && uvicorn backend.api.main:app --reload --port 8765",
    "backend:install": "cd backend && python3 -m venv .venv && source .venv/bin/activate && pip install -e .",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "license": "MIT",
  "dependencies": {
    "@annotorious/annotorious": "^3.7.19",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@thisux/sveltednd": "^0.0.20",
    "bits-ui": "^2.15.4",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "marked": "^17.0.2",
    "monaco-editor": "^0.55.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.1",
    "@lucide/svelte": "^0.561.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.0.5",
    "@types/three": "^0.182.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
